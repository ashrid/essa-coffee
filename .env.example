# Database
DATABASE_URL="postgresql://user:password@localhost:5432/shopseeds"

# Auth.js v5 (next-auth@5)
AUTH_SECRET="generate-with-openssl-rand-hex-32"
AUTH_URL="http://localhost:3000"

# Admin Access (must match your Gmail address)
ADMIN_EMAIL="your-email@gmail.com"

# Gmail SMTP (for auth magic links and order notification emails)
# Get app password: Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER="your-email@gmail.com"
GMAIL_APP_PASSWORD="your-16-char-app-password"

# App URL (used for links in emails)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Allowed Origins (comma-separated) for security validation
# Include all domains your app runs on (localhost, production, ngrok, etc.)
ALLOWED_ORIGINS="http://localhost:3000,https://localhost:3000"

# Upstash Redis (optional - for production rate limiting)
# Get from: https://upstash.com/
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Stripe (optional - only if using Stripe payments)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Shop Info (shown on the Pickup Information page)
SHOP_ADDRESS_LINE1="Essa Cafe"
SHOP_ADDRESS_LINE2="Dubai, UAE"
SHOP_PHONE="+971 XX XXX XXXX"
# Google Maps embed URL — get it from:
# Google Maps → search your location → Share → Embed a map → copy the src URL from the iframe
GOOGLE_MAPS_EMBED_URL=""

# Shop Hours (used for checkout validation and display — adjust seasonally)
# Format: "HH:MM-HH:MM" for open hours, "closed" for closed days
SHOP_HOURS_WEEKDAY="09:00-18:00"
SHOP_HOURS_SATURDAY="09:00-17:00"
SHOP_HOURS_SUNDAY="closed"
